# SWC Digital 3.1 — Wi-Fi usage push service example config.
# Copy to tools/wifi-usage.toml (gitignored) and edit.

[device]
# The Device ID printed by `pair` or shown on the Setup screen. The service
# selects ONLY this device on the LAN (fails closed if another device shares
# the same id). Leave empty to broadcast to the first device found (NOT
# recommended once you have paired).
id = ""

# Optional explicit URL fallback when mDNS discovery fails (e.g. when the
# device is on a different subnet). Default: empty, mDNS only.
url = ""

[service]
interval_seconds = 60
mdns_timeout_seconds = 2.0
# Legacy: explicit URLs. Merged with mDNS. Empty by default.
urls = []

# Pairing keys live in macOS Keychain (service com.night.swc-digital.device-<id>,
# account "pairkey"), NOT in this file. Run `wifi_usage_service.py pair` to
# generate one and store it. This file never holds credentials.
